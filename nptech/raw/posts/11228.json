valign=\"top\" height=\"76\"><img data-recalc-dims=\"1\" loading=\"lazy\" decoding=\"async\" alt=\"\" src=\"https://i0.wp.com/www.diosacommunications.com/diosagraphics/bloggers/nonprofitorgs.jpg?resize=73%2C73\" width=\"73\" height=\"73\" border=\"1\" /></td>\n<td height=\"76\"><strong>Nonprofit Tech 2.0 :: @</strong><a href=\"https://twitter.com/nonprofitorgs\">NonprofitOrgs</a><br />\nSocial Media, Mobile Commuicatons &amp; Fundraising, Training<br />\n<a href=\"http://www.nonprofitorgsblog.org\">nonprofitorgsblog.org</a></td>\n</tr>\n<tr valign=\"top\">\n<td height=\"76\"><strong>20.</strong></td>\n<td colspan=\"5\" align=\"center\" valign=\"top\" height=\"76\"><img data-recalc-dims=\"1\" loading=\"lazy\" decoding=\"async\" alt=\"\" src=\"https://i0.wp.com/www.diosacommunications.com/nonprofitresources/NTEN.jpg?resize=73%2C73\" width=\"73\" height=\"73\" border=\"1\" /></td>\n<td height=\"76\"><strong>Nonproft Technology Network :: @</strong><a href=\"https://twitter.com/NTENorg\">NTEN</a><br />\nNonprofit Technology, News, Training<br />\n<a href=\"http://www.nten.org/\">nten.org</a></td>\n</tr>\n<tr valign=\"top\">\n<td height=\"76\"><strong>21.</strong></td>\n<td colspan=\"5\" align=\"center\" valign=\"top\" height=\"76\"><img data-recalc-dims=\"1\" loading=\"lazy\" decoding=\"async\" alt=\"\" src=\"https://i0.wp.com/www.diosacommunications.com/nonprofitresources/NonprofitTimes.gif?resize=73%2C73\" width=\"73\" height=\"73\" border=\"1\" /></td>\n<td height=\"76\"><strong>Nonprofit Times :: @</strong><a href=\"https://twitter.com/NonProfitTimes\">NonProfitTimes</a><br />\nNews, Jobs, Management<br />\n<a href=\"http://www.thenonprofittimes.com/\">thenonprofittimes.com</a></td>\n</tr>\n<tr valign=\"top\">\n<td height=\"76\"><strong>22.</strong></td>\n<td colspan=\"5\" align=\"center\" valign=\"top\" height=\"76\"><img data-recalc-dims=\"1\" loading=\"lazy\" decoding=\"async\" alt=\"\" src=\"https://i0.wp.com/www.diosacommunications.com/nonprofitresources/osocio.jpg?resize=73%2C73\" width=\"73\" height=\"73\" border=\"1\" /></td>\n<td height=\"76\"><strong>Osocio :: @</strong><a href=\"https://twitter.com/osocio\">Osocio<br />\n</a>Advertising, Cause Marketing, Activism<br />\n<a href=\"http://osocio.org/\">osocio.org</a></td>\n</tr>\n<tr valign=\"top\">\n<td height=\"76\"><strong>23.</strong></td>\n<td colspan=\"5\" align=\"center\" valign=\"top\" height=\"76\"><img data-recalc-dims=\"1\" loading=\"lazy\" decoding=\"async\" alt=\"\" src=\"https://i0.wp.com/www.diosacommunications.com/nonprofitresources/PewInternet.jpg?resize=73%2C73\" width=\"73\" height=\"73\" border=\"1\" /></td>\n<td height=\"76\"><strong>Pew Internet &amp; American Life Project :: @</strong><a href=\"https://twitter.com/pewinternet\">PewInternet</a><br />\nResearch, Data, Statistics<br />\n<a href=\"http://pewinternet.org/\">pewinternet.org</a></td>\n</tr>\n<tr valign=\"top\">\n<td height=\"76\"><strong>24.</strong></td>\n<td colspan=\"5\" align=\"center\" valign=\"top\" height=\"76\"><img data-recalc-dims=\"1\" loading=\"lazy\" decoding=\"async\" alt=\"\" src=\"https://i0.wp.com/www.diosacommunications.com/nonprofitresources/Socialbrite.gif?resize=73%2C73\" width=\"73\" height=\"73\" border=\"1\" /></td>\n<td height=\"76\">Socialbrite :: @<a href=\"https://twitter.com/socialbrite\">Socialbrite</a><br />\nSocial Media, Fundraising, Nonprofit Technology<br />\n<a href=\"http://www.socialbrite.org/\">socialbrite.org</a></td>\n</tr>\n<tr valign=\"top\">\n<td height=\"76\"><strong>25.</strong></td>\n<td colspan=\"5\" align=\"center\" valign=\"top\" height=\"76\"><img data-recalc-dims=\"1\" loading=\"lazy\" decoding=\"async\" alt=\"\" src=\"https://i0.wp.com/www.diosacommunications.com/nonprofitresources/Souktel.jpg?resize=73%2C73\" width=\"73\" height=\"73\" border=\"1\" /></td>\n<td height=\"76\"><strong>Souktel :: @</strong><a href=\"https://twitter.com/souktel\">Souktel</a><br />\nMobile Communications, Nonprofit Technology, Middle East<br />\n<a href=